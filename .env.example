# Example environment variables for the nsupdate.info Docker container.
# Copy this file to .env and customize the values for your environment.

# --- Django Secret Key (REQUIRED FOR PRODUCTION) ---
# A long, random string used for cryptographic signing.
# IMPORTANT: This key must be kept secret.
# Generate a new key with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-very-long-and-random-secret-key

# --- Superuser Credentials (REQUIRED ON FIRST RUN) ---
# These are used to create the initial administrator account.
# SECURITY: the password is only needed for the very first start. Remove it from
# this file afterwards so it no longer lingers in the container environment.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@your-domain.com
DJANGO_SUPERUSER_PASSWORD=your-super-secret-password

# --- Database Configuration (OPTIONAL) ---
# The default is an SQLite database inside the 'database' volume.
# Uncomment and configure the line below to use an external database (e.g., PostgreSQL).
# DATABASE_URL="postgres://user:password@host:port/dbname"

# --- Gunicorn Configuration (RECOMMENDED) ---
# Comma-separated list of trusted sources for X-Forwarded-* headers.
# SECURITY: do NOT use '*' -- it lets any client spoof its IP via X-Forwarded-For,
# which nsupdate relies on for IP updates and abuse/fault counting. Set this to
# your reverse proxy's IP or the proxy network CIDR.
GUNICORN_FORWARDED_ALLOW_IPS=172.18.0.0/16
